# Required: Broadcastify stream URL
STREAM_URL=https://broadcastify.cdnstream1.com/12345

# Optional: Ollama settings (default: local server with llama3.1:8b)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Optional: Whisper model (default: base.en)
WHISPER_MODEL=base.en

# Optional: Whisper binary path (default: whisper)
WHISPER_PATH=whisper

# Optional: Google Maps API key for better geocoding (falls back to OpenStreetMap if not set)
# Get a free key at https://console.cloud.google.com/google/maps-apis
GOOGLE_MAPS_API_KEY=

# Optional: Locality for geocoding disambiguation (default: "")
GEOCODE_CITY=Los Angeles
GEOCODE_STATE=CA
GEOCODE_COUNTRY=US

# Optional: Server port (default: 3000)
PORT=3000

# Optional: Default map center (default: Los Angeles)
MAP_CENTER_LAT=34.0522
MAP_CENTER_LNG=-118.2437
MAP_ZOOM=12

# Optional: Seconds to skip at start of each stream connection (ad period)
# Broadcastify plays 15-30s of ads on each connect. Set to 0 to disable.
AD_SKIP_SECONDS=30

# Optional: Audio chunk duration in seconds (default: 15)
CHUNK_DURATION=15
